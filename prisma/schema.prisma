generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id            String    @id @default(uuid())
  phone         String    @unique
  email         String?   @unique
  password      String
  name          String?
  gender        String?
  age_range     String?
  district      String?
  is_admin      Boolean   @default(false)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  refreshTokens RefreshToken[]
  timeline      Timeline?
  followers     Follower[]       @relation("Followers")
  following     Follower[]       @relation("Following")

  @@map("users")
}

model RefreshToken {
  id         String    @id @default(uuid())
  user_id    String
  token      String    @unique
  expires_at DateTime
  created_at DateTime  @default(now())

  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ============================================
// TIMELINE SHARING (Family/Caregiver - Future)
// ============================================

model Timeline {
  id          String    @id @default(uuid())
  user_id     String    @unique
  share_token String    @unique @default(uuid())
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  followers  Follower[]

  @@map("timelines")
}

model Follower {
  id               String    @id @default(uuid())
  timeline_id      String
  follower_user_id String
  user_id          String
  notify_missed    Boolean   @default(false)
  notify_refill    Boolean   @default(false)
  is_active        Boolean   @default(true)
  created_at       DateTime  @default(now())

  timeline  Timeline @relation(fields: [timeline_id], references: [id], onDelete: Cascade)
  follower  User    @relation("Followers", fields: [follower_user_id], references: [id], onDelete: Cascade)
  user      User    @relation("Following", fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([timeline_id, follower_user_id])
  @@map("followers")
}

// ============================================
// DATA COLLECTION (Anonymous Analytics)
// ============================================

model AnalyticsEvent {
  id          String   @id @default(uuid())
  event_type  String
  event_data  Json?
  device_info Json?
  created_at  DateTime @default(now())

  @@index([event_type, created_at])
  @@map("analytics_events")
}

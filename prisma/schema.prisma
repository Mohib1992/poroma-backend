generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id            String    @id @default(uuid())
  phone         String    @unique
  email         String?   @unique
  password      String
  name          String?
  gender        String?
  age_range     String?
  district      String?
  is_admin      Boolean   @default(false)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  medications   Medication[]
  logs          MedicationLog[]
  timeline      Timeline?
  followers     Follower[]       @relation("Followers")
  following     Follower[]       @relation("Following")
  analytics     AnalyticsEvent[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  user_id   String
  token     String   @unique
  expires_at DateTime
  created_at DateTime @default(now())

  @@map("refresh_tokens")
}

// ============================================
// MEDICATION MANAGEMENT
// ============================================

model Medication {
  id              String    @id @default(uuid())
  user_id         String
  name            String
  name_bn         String?
  dosage          String
  frequency       String
  times           String[]
  duration        Int?
  start_date      DateTime
  end_date        DateTime?
  notes           String?
  pharmacy_id     String?
  stock_count     Int?
  refill_alert_days Int     @default(7)
  is_active       Boolean   @default(true)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  user            User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  pharmacy        Pharmacy? @relation(fields: [pharmacy_id], references: [id])
  logs            MedicationLog[]

  @@map("medications")
}

model MedicationLog {
  id             String    @id @default(uuid())
  medication_id  String
  user_id        String
  scheduled_time String
  status         String
  taken_at       DateTime?
  skipped_at     DateTime?
  date           DateTime  @default(now())
  created_at     DateTime  @default(now())

  medication     Medication @relation(fields: [medication_id], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, date])
  @@map("medication_logs")
}

// ============================================
// PHARMACY NETWORK
// ============================================

model Pharmacy {
  id           String    @id @default(uuid())
  name         String
  license_no   String?
  address      String
  area         String
  district     String
  lat          Float?
  lng          Float?
  phone        String?
  website      String?
  has_delivery Boolean   @default(false)
  tier         String    @default("basic")
  is_verified  Boolean   @default(false)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  medications  Medication[]

  @@map("pharmacies")
}

// ============================================
// TIMELINE SHARING (Family/Caregiver)
// ============================================

model Timeline {
  id          String    @id @default(uuid())
  user_id     String    @unique
  share_token String    @unique @default(uuid())
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  followers  Follower[]

  @@map("timelines")
}

model Follower {
  id               String    @id @default(uuid())
  timeline_id      String
  follower_user_id String
  user_id          String
  notify_missed    Boolean   @default(false)
  notify_refill    Boolean   @default(false)
  is_active        Boolean   @default(true)
  created_at       DateTime  @default(now())

  timeline  Timeline @relation(fields: [timeline_id], references: [id], onDelete: Cascade)
  follower  User    @relation("Followers", fields: [follower_user_id], references: [id], onDelete: Cascade)
  user      User    @relation("Following", fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([timeline_id, follower_user_id])
  @@map("followers")
}

// ============================================
// DATA COLLECTION (Analytics)
// ============================================

model AnalyticsEvent {
  id          String   @id @default(uuid())
  user_id     String?
  event_type  String
  event_data  Json
  device_info Json?
  created_at  DateTime @default(now())

  user        User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([event_type, created_at])
  @@index([user_id])
  @@map("analytics_events")
}

// ============================================
// SCHEDULED REMINDERS (for background jobs)
// ============================================

model ScheduledReminder {
  id            String    @id @default(uuid())
  user_id       String
  medication_id String
  scheduled_at  DateTime
  status        String    @default("pending")
  sent_at       DateTime?
  created_at    DateTime  @default(now())

  @@index([scheduled_at, status])
  @@map("scheduled_reminders")
}
